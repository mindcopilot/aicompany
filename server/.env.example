# Copy to .env (server/.env) for local dev.
# Points at the agentos-infra-postgres-1 container in Docker by default.

DATABASE_URL=postgres://agentos:agentos@127.0.0.1:5432/lumenedu
PORT=8787

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Temporal — agentos-infra-temporal-1
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=lumenedu-main

# Langfuse — agentos-infra-langfuse-web-1. Create a project in the UI and paste keys.
# Leave blank to disable tracing (LLM still works; calls won't be traced).
LANGFUSE_HOST=http://127.0.0.1:3030
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
